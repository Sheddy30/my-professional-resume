name: My first pipeline

on:
    push:
        branches: [ "main" ]

jobs:     
    build:
        runs-on: ubuntu-latest # macos, windows-latest
        steps:
            - name: Clone the code
              uses: actions/checkout@v4
            - name:  Build image
              run:
                docker build -t sheddy30/cicd-portfolio .
            - name: Docker login
              uses: docker/login-action@v3
              with:
                username: sheddy30
                password: ${{ secrets.DOCKER_PASS }}
            - name: Push image
              run:
                docker push sheddy30/cicd-portfolio
